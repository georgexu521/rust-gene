{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Priority Agent",
  "version": "0.1.0",
  "identifier": "com.priorityagent.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Priority Agent",
        "width": 1280,
        "height": 820,
        "minWidth": 920,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://127.0.0.1:*; object-src 'none'; frame-ancestors 'none';"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "icon": ["icons/icon.png", "icons/icon.icns"]
  }
}
