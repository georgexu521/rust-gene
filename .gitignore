/target
.DS_Store
**/.DS_Store
__pycache__/
*.pyc

# Desktop app local build artifacts
apps/desktop/dist/
apps/desktop/node_modules/
apps/desktop/test-artifacts/
apps/desktop/test-results/
apps/desktop/src-tauri/gen/
apps/desktop/src-tauri/target/

# Live eval transient artifacts. Keep curated summaries/reports in docs, but
# avoid committing raw API payloads, server logs, and generated patch dumps.
docs/benchmarks/live-*/**/api-response.json
docs/benchmarks/live-*/**/api-response.headers
docs/benchmarks/live-*/**/api-server.log
docs/benchmarks/live-*/**/plan-lint.txt
docs/benchmarks/live-*/**/request.json
docs/benchmarks/live-*/**/system-prompt.txt
docs/benchmarks/live-*/**/repo-context.txt
docs/benchmarks/live-*/**/minimax-plan.md
docs/benchmarks/live-*/**/diff.patch
docs/benchmarks/live-*/**/diff-stat.txt
docs/benchmarks/live-*/**/git-status.txt
docs/benchmarks/live-*/**/required-commands.log

# Daily gate generated run bundles (use --clean to remove)
eval-benchmarks/
eval-summaries/
docs/benchmarks/live-product-daily*/
.priority-agent/
.reasonix/
