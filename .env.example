# ============================================================
# Priority Agent - 环境变量配置
# ============================================================
# 复制此文件为 .env 并填写你的实际配置

# --------------------
# Kimi (Moonshot AI) API 配置
# --------------------

# 你的 Kimi API Key（从 https://platform.moonshot.ai/console/api-keys 获取）
MOONSHOT_API_KEY=your_moonshot_api_key_here

# 基础 URL（国内用户可以使用 https://api.moonshot.cn/v1）
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# 默认模型
# 可选: kimi-k2.5, kimi-k2-thinking, kimi-k2-thinking-turbo, kimi-k2-turbo-preview
MOONSHOT_MODEL=kimi-k2.5

# --------------------
# Claude Code 兼容模式配置（可选）
# --------------------
# 如果你想让 Priority Agent 像 Claude Code 一样使用 Kimi API，设置这些变量：

# ANTHROPIC_BASE_URL=https://api.moonshot.ai/anthropic
# ANTHROPIC_AUTH_TOKEN=your_moonshot_api_key_here
# ANTHROPIC_MODEL=kimi-k2.5

# --------------------
# 日志级别
# --------------------
# 可选: trace, debug, info, warn, error
RUST_LOG=info

# --------------------
# 应用配置
# --------------------
# 数据存储目录（默认使用系统数据目录）
# PRIORITY_AGENT_DATA_DIR=~/.priority-agent

# 会话持久化（默认启用）
# PRIORITY_AGENT_PERSISTENCE=true
